{
  "name": "turbo-fiverr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "artifacts/*",
    "lib/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspaces --if-present",
    "build:api-server": "npm run build --workspace=@turbo/api-server",
    "build:mockup-sandbox": "npm run build --workspace=@turbo/mockup-sandbox",
    "build:api-client-react": "npm run build --workspace=@turbo/api-client-react",
    "test": "npm run test --workspaces --if-present",
    "test:api-server": "npm run test --workspace=@turbo/api-server",
    "test:mockup-sandbox": "npm run test --workspace=@turbo/mockup-sandbox",
    "test:api-client-react": "npm run test --workspace=@turbo/api-client-react",
    "lint": "eslint artifacts/ lib/ --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint artifacts/ lib/ --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"artifacts/**/*.{ts,tsx,js,jsx,json,md}\" \"lib/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"artifacts/**/*.{ts,tsx,js,jsx,json,md}\" \"lib/**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf artifacts/*/dist artifacts/*/node_modules lib/*/dist lib/*/node_modules node_modules",
    "dev:api-server": "npm run dev --workspace=@turbo/api-server",
    "dev:mockup-sandbox": "npm run dev --workspace=@turbo/mockup-sandbox"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "engineStrict": true
}
